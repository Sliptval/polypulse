# Telegram
TELEGRAM_BOT_TOKEN=          # токен от @BotFather
TELEGRAM_CHANNEL_ID=         # @channel_username или -100xxxxxxxxxx
ADMIN_CHAT_ID=               # личный chat_id владельца — для сервисных уведомлений об ошибках

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Поведение
POLL_INTERVAL_MINUTES=10     # частота опроса Gamma API
PRICE_DELTA_THRESHOLD=0.07   # сдвиг вероятности за окно (7 п.п.)
PRICE_DELTA_WINDOW_MIN=60    # окно сравнения, минут
VOLUME_SPIKE_MULTIPLIER=4    # во сколько раз объём окна должен превысить медианный
MIN_MARKET_VOLUME_USD=50000  # игнорировать неликвидные рынки ниже этого total volume
NEW_MARKET_VOLUME_USD=100000 # порог «крупный новый рынок»
MAX_ALERTS_PER_HOUR=6        # анти-спам канала
DRY_RUN=false                # true = алерты в лог, не в Telegram
